# ─── Supabase ────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key, used by API routes (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Site ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Optional: Google Places (for live reviews sync) ─────────
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ─── Safepay (card payments) ─────────────────────────────────
# Sandbox dashboard: https://sandbox.api.getsafepay.com
# Production dashboard: https://getsafepay.com

SAFEPAY_ENVIRONMENT=sandbox                      # sandbox | production
SAFEPAY_API_KEY=                                 # Client key (sec_...)
SAFEPAY_V1_SECRET=                               # Merchant / V1 secret
SAFEPAY_WEBHOOK_SECRET=                          # Set after creating the webhook in the dashboard

# ─── Admin (currently unused; reserved) ──────────────────────
ADMIN_SESSION_SECRET=

# ─── Optional: Resend / email notifications ──────────────────
RESEND_API_KEY=
NOTIFY_EMAIL=hello@mesetacoffee.com
